FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_VIETQR_BANK_ID
ARG VITE_VIETQR_ACCOUNT_NO
ARG VITE_VIETQR_ACCOUNT_NAME
ARG VITE_VIETQR_TEMPLATE=compact2

ENV VITE_VIETQR_BANK_ID=$VITE_VIETQR_BANK_ID
ENV VITE_VIETQR_ACCOUNT_NO=$VITE_VIETQR_ACCOUNT_NO
ENV VITE_VIETQR_ACCOUNT_NAME=$VITE_VIETQR_ACCOUNT_NAME
ENV VITE_VIETQR_TEMPLATE=$VITE_VIETQR_TEMPLATE

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
